# Admin Panel Configuration
# Development (use /api so Vite proxies API, uploads, and Socket.IO on one origin)
VITE_API_BASE_URL=/api
# Or direct backend: VITE_API_BASE_URL=http://localhost:5000/api

# Production (Vercel admin + Railway API — REQUIRED):
# VITE_API_BASE_URL=https://fixitnow-backand-production.up.railway.app/api
# VITE_SOCKET_URL=https://fixitnow-backand-production.up.railway.app
# VITE_USE_HTTPONLY_COOKIES=false
# (Cross-origin is auto-detected; set false explicitly if session still fails.)

# Production (single admin host with reverse proxy for /api, /uploads, /socket.io):
# VITE_API_BASE_URL=/api
# VITE_USE_HTTPONLY_COOKIES=true
