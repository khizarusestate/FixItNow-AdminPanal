# Admin Panel Configuration

# Production (Vercel + Railway — used automatically when VITE_* unset in prod build):
# VITE_API_BASE_URL=https://fixitnow-backand-production.up.railway.app/api
# VITE_SOCKET_URL=https://fixitnow-backand-production.up.railway.app
# VITE_USE_HTTPONLY_COOKIES=false

# Local development — Vite proxies /api, /uploads, /socket.io to backend on :5000
VITE_API_BASE_URL=/api

# Or direct local backend:
# VITE_API_BASE_URL=http://localhost:5000/api
