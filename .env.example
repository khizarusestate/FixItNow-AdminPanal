# Admin Panel Configuration
# Development (use /api so Vite proxies API, uploads, and Socket.IO on one origin)
VITE_API_BASE_URL=/api
# Or direct backend: VITE_API_BASE_URL=http://localhost:5000/api

# Production (split hosts — API on its own domain):
# VITE_API_BASE_URL=https://api.your-domain.com/api
# VITE_SOCKET_URL=https://api.your-domain.com

# Production (single admin host with reverse proxy for /api, /uploads, /socket.io):
# VITE_API_BASE_URL=/api
